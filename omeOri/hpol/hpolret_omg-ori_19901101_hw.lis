 CALIBRAT= 'pbo2c4  '           / Instrumental polarization calibration used     
 AVE-POL =                0.506 / Mean %Pol over entire wavelength region        
 AVE-ERRO=                0.003 / Mean %Error in %Pol                            
 AVE-PA  =                42.91 / Mean Position Angle (degrees)                  
 U-POL   =                0.428 / Synthetic U Filter %Polarization               
 U-ERR   =                0.007 / Synthetic U Filter %Error                      
 U-PA    =                42.04 / Synthetic U Filter Position Angle (Deg)        
 B-POL   =                0.524 / Synthetic B Filter %Polarization               
