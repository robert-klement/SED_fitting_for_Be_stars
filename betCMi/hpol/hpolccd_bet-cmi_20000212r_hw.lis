 EXTNAME = 'polarimetry'        / name of this binary table extension            
 CALIBRAT= 'pbo3aB  '           / Instrumental polarization calibration used     
 AVE-POL =                0.065 / Mean %Pol over entire wavelength region        
 AVE-ERRO=                0.002 / Mean %Error in %Pol                            
 AVE-PA  =                38.84 / [deg] Mean Position Angle                      
