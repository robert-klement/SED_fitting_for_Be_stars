 TFIELDS =                    4 / number of fields in each row                   
 TTYPE1  = 'wavelength'         / label for field   1                            
 TFORM1  = '1200E   '           / data format of field: 4-byte REAL              
 TUNIT1  = 'angstrom'           / physical unit of field                         
